{
  "name": "shabaily/cmss",
  "description": "A lightweight, security focused, content management system",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Matt Shabaily"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": "^7.4",
    "nikic/fast-route": "^1.3",
    "symfony/security-csrf": "^5.4",
    "respect/validation": "^2.2",
    "spomky-labs/otphp": "^10.0.0",
    "vlucas/phpdotenv": "^5.6",
    "bepsvpt/secure-headers": "^7.0",
    "monolog/monolog": "^2.9",
    "intervention/image": "^2.7",
    "phpmailer/phpmailer": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload": {
    "psr-4": {
      "CMSS\\": "src/classes/"
    },
    "classmap": [
      "src/traits/"
    ]
  },
  "config": {
    "platform": {
      "php": "7.4.33"
    },
    "sort-packages": true
  }
}
